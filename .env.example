# TCG Pre-Grader — Environment Configuration
# Copy this file to .env and fill in values before running the application.
# Never commit .env to version control.

# ---------------------------------------------------------------------------
# Model Artifact Paths
# ---------------------------------------------------------------------------
# Required: path to the TF SavedModel directory for Pokemon cards.
POKEMON_MODEL_ARTIFACT_PATH=/path/to/artifacts/pokemon_savedmodel

# Optional: set these when the corresponding model artifacts are ready.
# ONE_PIECE_MODEL_ARTIFACT_PATH=/path/to/artifacts/one_piece_savedmodel
# SPORTS_MODEL_ARTIFACT_PATH=/path/to/artifacts/sports_savedmodel

# ---------------------------------------------------------------------------
# Model Registry Bootstrap
# ---------------------------------------------------------------------------
# Comma-separated list of card types to load at startup.
# Only types with a corresponding artifact path above will load successfully.
ENABLED_CARD_TYPES=pokemon

# ---------------------------------------------------------------------------
# Preprocessing
# ---------------------------------------------------------------------------
# Must match the input shape the model was trained on.
# Changing these without retraining will silently degrade accuracy.
INPUT_WIDTH=224
INPUT_HEIGHT=312

# ---------------------------------------------------------------------------
# Ingestion Limits
# ---------------------------------------------------------------------------
MAX_BATCH_SIZE=50

# ---------------------------------------------------------------------------
# API Server
# ---------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------
# One of: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ===========================================================================
# Training Data Pipeline (data_pipeline/)
# ===========================================================================

# ---------------------------------------------------------------------------
# PSA Public API — REQUIRED
# ---------------------------------------------------------------------------
# Bearer token for api.psacard.com. Never commit the real value.
# Obtain from: https://www.psacard.com/api
PSA_API_TOKEN=your_psa_api_token_here

# ---------------------------------------------------------------------------
# PSA Client tuning
# ---------------------------------------------------------------------------
# Max API calls per 24-hour window (default: 500)
# PSA_DAILY_QUOTA=500

# Path to JSON file that persists the daily call counter across restarts
# PSA_QUOTA_STATE_PATH=.quota_state.json

# PSA cert lookup base URL (rarely needs changing)
# PSA_BASE_URL=https://api.psacard.com/publicapi/cert/GetByCertNumber/

# ---------------------------------------------------------------------------
# Deduplication state
# ---------------------------------------------------------------------------
# Path to JSON file persisting seen cert numbers across pipeline runs
# SEEN_CERTS_PATH=.seen_certs.json

# ---------------------------------------------------------------------------
# Scraper — crawl delays and per-grade limits
# ---------------------------------------------------------------------------
# Minimum seconds between consecutive requests to eBay (default: 1.0)
# EBAY_CRAWL_DELAY=1.0

# Minimum seconds between consecutive requests to cardladder.com (default: 3.0)
# CARDLADDER_CRAWL_DELAY=3.0

# Max eBay listings to process per PSA grade per run (default: 500)
# MAX_LISTINGS_PER_GRADE=500

# Max Card Ladder records to process per PSA grade per run (default: 500)
# MAX_RECORDS_PER_GRADE=500

# Semaphore size for concurrent HTTP requests within a scraper (default: 5)
# MAX_CONCURRENT_REQUESTS=5

# ---------------------------------------------------------------------------
# Image quality thresholds
# ---------------------------------------------------------------------------
# Laplacian variance floor — images below this are rejected as blurry (default: 100.0)
# MIN_SHARPNESS=100.0

# Mean luminance floor on 0–255 scale — below this = underexposed (default: 30.0)
# MIN_LUMINANCE=30.0

# Mean luminance ceiling on 0–255 scale — above this = overexposed/glare (default: 230.0)
# MAX_LUMINANCE=230.0

# Max slab tilt in degrees before perspective correction is attempted (default: 5.0)
# MAX_SKEW_ANGLE=5.0

# ---------------------------------------------------------------------------
# Augmentation probabilities (training images only)
# ---------------------------------------------------------------------------
# Probability of applying glare simulation per training image (default: 0.3)
# GLARE_PROBABILITY=0.3

# Probability of occluding the PSA label region per training image (default: 0.5)
# LABEL_OCCLUSION_PROBABILITY=0.5

# ---------------------------------------------------------------------------
# Output paths
# ---------------------------------------------------------------------------
# Directory where downloaded slab images are saved (default: data/raw_slabs/)
# OUTPUT_DIR=data/raw_slabs/

# Path to the manifest CSV consumed by ManifestLoader (default: data/manifest.csv)
# MANIFEST_PATH=data/manifest.csv

# ---------------------------------------------------------------------------
# CNN input dimensions — must match the model's expected input shape
# Image tensor shape convention: (HEIGHT, WIDTH, CHANNELS)
# ---------------------------------------------------------------------------
# TARGET_INPUT_WIDTH=224
# TARGET_INPUT_HEIGHT=224

# Fraction of image height occupied by the PSA label region (default: 0.15)
# LABEL_REGION_FRACTION=0.15
